{
  "name": "digigro-ai",
  "version": "1.0.0",
  "private": true,
  "description": "DIGIGRO AI — Express AI app builder",
  "type": "module",
  "main": "app.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "build": "npm install --prefix frontend --include=dev && npm run build --prefix frontend",
    "start": "node scripts/ensure-build.js && node app.js",
    "db:init": "node backend/src/config/initDb.js",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@babel/standalone": "^7.29.7",
    "@octokit/rest": "^20.1.1",
    "archiver": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.12.0",
    "openai": "^4.77.0",
    "uuid": "^11.0.5"
  }
}
