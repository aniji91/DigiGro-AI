PORT=5000
NODE_ENV=development

# MySQL
# Local: DB_HOST=localhost, DB_USER=root, DB_NAME=digigro_ai
# Hostinger (on server): DB_HOST=localhost
# Hostinger (remote from PC): use hostname from hPanel → Databases → MySQL (e.g. srv1234.hstgr.io)
DB_HOST=localhost
DB_PORT=3306
DB_USER=digigro
DB_PASSWORD=digigro_secret
DB_NAME=digigro_ai

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# Anthropic Claude (primary — same as Lovable)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (optional fallback if no Claude key)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Vercel hosting (publish deploys to *.vercel.app)
# Create token: https://vercel.com/account/tokens
VERCEL_TOKEN=
# Optional team ID for Vercel teams
VERCEL_TEAM_ID=
