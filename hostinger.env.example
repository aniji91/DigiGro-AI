NODE_ENV=production
PORT=3000

# MySQL (Hostinger — use localhost when app runs on same server)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# JWT — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (optional fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Your live site URL (for CORS)
FRONTEND_URL=https://your-domain.hostingersite.com

# Vercel publish (optional)
VERCEL_TOKEN=
VERCEL_TEAM_ID=
