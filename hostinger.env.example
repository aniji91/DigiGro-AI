# Hostinger deploy settings (hPanel → Deployments → Settings):
#
# Framework:     Express.js  (NOT "Other" — required for API + SPA routing)
# Entry file:    app.js
# Build command: npm run build
# Start command: npm start
# Output dir:    public
# Node version:  22.x  (NOT 18.x)
#
# After changing settings, click Redeploy. Use Runtime logs if you see 503.

NODE_ENV=production

# Do NOT set PORT — Hostinger injects it automatically
#
# RECOMMENDED for Hostinger (avoids $ and ? being mangled in DB_PASSWORD):
# Use ONE connection string — password must be URL-encoded:
#   ? → %3F   * → %2A   $ → %24   ~ → %7E
# Example: mysql://USER:ENCODED_PASSWORD@localhost:3306/DB_NAME
DATABASE_URL=mysql://u331715773_digigro_ai:YOUR_URL_ENCODED_PASSWORD@localhost:3306/u331715773_digigro_ai
#
# OR use separate vars (avoid $ ? * ~ in password, or use DB_PASSWORD_B64):
DB_HOST=localhost
DB_PORT=3306
DB_USER=u331715773_digigro_ai
DB_PASSWORD=your-mysql-password
DB_NAME=u331715773_digigro_ai
# DB_PASSWORD_B64=base64-encoded-password

# JWT — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (optional fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Your live site URL (for CORS)
FRONTEND_URL=https://teal-jellyfish-675904.hostingersite.com/

# Vercel publish (optional)
VERCEL_TOKEN=
VERCEL_TEAM_ID=
